# Cadrex environment example
# Copia a .env para local o carga en Coolify. Nunca guardes secretos reales aqui.

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=bris_adriana
MYSQL_USER=bris_user
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

SECRET_KEY=
UPLOAD_SECRET=
APP_TITLE=Cadrex | Adriana Ramos
PORT=8743
FLASK_ENV=production
LOGIN_REQUIRED=false

AVAILABLE_SECONDS=39900
TAKT_SECONDS=2216.666667
DATA_FILE=/app/data/stations.csv

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ADMIN_ID=
TELEGRAM_DEFAULT_USER=bris

FIZZY_API_KEY=
FIZZY_BASE_URL=https://fizzy-br.soul23.cloud

SERVICE_URL_DASHBOARD=https://abr.soul23.cloud/cadrex/
SERVICE_FQDN_DASHBOARD=abr.soul23.cloud
SERVICE_URL_CADREX=https://abr.soul23.cloud
SERVICE_FQDN_CADREX=abr.soul23.cloud

PWA_START_URL=/cadrex/
PWA_SCOPE=/cadrex/

LOG_LEVEL=INFO
REQUEST_LOG_LEVEL=INFO
CADREX_DB_SLOW_MS=250
