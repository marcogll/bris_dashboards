# Vanity HQ - Environment Configuration Template (Unificado)
# Copia este archivo como .env para producción

# === Servicios ===
PORT=5050
DEBUG=false

# === Dominios ===
COOLIFY_DOMAIN=vanityhq.soul23.cloud
MAIN_DOMAIN=vanityhq.soul23.cloud
EMPREQ_SUBDOMAIN=vanityerq
EMPREQ_DOMAIN=vanityerq.soul23.cloud

# === Seguridad ===
ALLOWED_HOSTS=vanityhq.soul23.cloud,www.vanityhq.soul23.cloud,vanityerq.soul23.cloud,localhost
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# === URLs internas (Docker Network) ===
VANITY_HQ_URL=http://hq-wrapper:5050
VANITY_DASHBOARD_URL=http://dashboard:5002
VANITY_HRMGR_URL=http://hrmgr-web:8000
VANITY_PAYROLL_URL=http://payroll:5051
VANITY_ACTAS_URL=http://actas:5052
VANITY_EMPREQ_URL=http://empreq:5053

# === URLs públicas (HTTPS) ===
VANITY_HQ_PUBLIC_URL=https://vanityhq.soul23.cloud
VANITY_DASHBOARD_PUBLIC_URL=https://vanityhq.soul23.cloud/dashboard
VANITY_HRMGR_PUBLIC_URL=https://vanityhq.soul23.cloud/empleadas
VANITY_PAYROLL_PUBLIC_URL=https://vanityhq.soul23.cloud/payroll
VANITY_ACTAS_PUBLIC_URL=https://vanityhq.soul23.cloud/actas
VANITY_EMPREQ_PUBLIC_URL=https://vanityerq.soul23.cloud

# === Secret Keys (Generar con: openssl rand -hex 32) ===
VANITY_HQ_SECRET_KEY=
VANITY_PAYROLL_SECRET_KEY=
VANITY_DASHBOARD_SECRET_KEY=
VANITY_ACTAS_SECRET_KEY=
VANITY_EMPREQ_SECRET_KEY=
VANITY_HRMGR_SECRET_KEY=

# === Base de Datos ===
POSTGRES_HOST=hrmgr-db
POSTGRES_DB=hrmgr_db
POSTGRES_USER=postgres
HRMGR_DB_PASSWORD=

CELERY_BROKER_URL=redis://hrmgr-redis:6379/0
CELERY_RESULT_BACKEND=redis://hrmgr-redis:6379/0

# === Payroll ===
PAYROLL_BASE_URL=http://payroll:5051
PAYROLL_PUBLIC_URL=https://vanityhq.soul23.cloud/payroll

# === Telegram & Sentry ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_DEFAULT_USER=bris
SENTRY_DSN=

# === PWA ===
# En abr.soul23.cloud el servicio vive bajo /cadrex.
PWA_START_URL=/cadrex/
PWA_SCOPE=/cadrex/

# === Session Configuration ===
SESSION_COOKIE_AGE=43200
SESSION_EXPIRE_AT_BROWSER_CLOSE=true
SESSION_COOKIE_HTTPONLY=true
CSRF_COOKIE_HTTPONLY=true

# === CORS ===
CORS_ALLOWED_ORIGINS=vanityhq.soul23.cloud,www.vanityhq.soul23.cloud,vanityerq.soul23.cloud

# === HRM Specific ===
HRMGR_ALLOWED_HOSTS=vanityhq.soul23.cloud,www.vanityhq.soul23.cloud,vanityerq.soul23.cloud,localhost
HRMGR_CSRF_TRUSTED_ORIGINS=https://vanityhq.soul23.cloud,https://www.vanityhq.soul23.cloud,https://vanityerq.soul23.cloud

# === Service URLs (Coolify) ===
SERVICE_URL_HQ_WRAPPER=https://vanityhq.soul23.cloud
SERVICE_FQDN_HQ_WRAPPER=vanityhq.soul23.cloud
SERVICE_URL_DASHBOARD=https://vanityhq.soul23.cloud/dashboard
SERVICE_FQDN_DASHBOARD=vanityhq.soul23.cloud/dashboard
SERVICE_URL_HRMGR_WEB=https://vanityhq.soul23.cloud/empleadas
SERVICE_FQDN_HRMGR_WEB=vanityhq.soul23.cloud/empleadas
SERVICE_URL_HRMGR_CELERY=https://hr-1.soul23.cloud
SERVICE_FQDN_HRMGR_CELERY=hr-1.soul23.cloud
SERVICE_URL_PAYROLL=https://vanityhq.soul23.cloud/payroll
SERVICE_FQDN_PAYROLL=vanityhq.soul23.cloud/payroll
